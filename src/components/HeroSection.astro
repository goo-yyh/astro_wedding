---
interface Props {
  eyebrow: string;
  title: string;
}

const { eyebrow, title } = Astro.props;
---

<section class="section-gap overflow-hidden pt-2 lg:pt-3">
  <div class="container-shell">
    <div class="reveal-up max-w-5xl">
      <span class="section-kicker">{eyebrow}</span>
      <h1 class="mt-5 max-w-[14ch] font-display text-[clamp(2.65rem,6vw,4.6rem)] leading-[0.96] font-bold tracking-[-0.05em] text-ink-strong lg:max-w-none lg:whitespace-nowrap">
        {title}
      </h1>
    </div>
  </div>
</section>
